{
  "$Comment": "Template for the Forklift Boss. Uses random attack selection between fork, turn, and leap attacks.",
  "Type": "Abstract",
  "Debug": "DisplayState",
  "StartState": "Idle",
  "Parameters": {
    "Appearance": {
      "Value": "Forklift",
      "Description": "Model to be used."
    },
    "NameTranslationKey": {
      "Value": "server.npcRoles.Template.name",
      "Description": "Translation key for NPC name display."
    },
    "MaxHealth": {
      "Value": 1000,
      "Description": "Max health for the NPC."
    },
    "MaxSpeed": {
      "Value": 6,
      "Description": "Maximum walking speed."
    },
    "RunThreshold": {
      "Value": 0.3,
      "Description": "Relative speed at which run animation should be used."
    },
    "ViewRange": {
      "Value": 22,
      "Description": "The range from which the target will be seen."
    },
    "ViewSector": {
      "Value": 140,
      "Description": "The view sector within which the target needs to be to be seen."
    },
    "HearingRange": {
      "Value": 14,
      "Description": "The range from which the target will be heard."
    },
    "AbsoluteDetectionRange": {
      "Value": 6,
      "Description": "Guaranteed detection distance."
    },
    "AlertedRange": {
      "Value": 28,
      "Description": "Detection range while in combat/search."
    },
    "AlertedTime": {
      "Value": [1, 2],
      "Description": "How long to wait in alerted state before switching to combat."
    },
    "WakingPeriod": {
      "Value": [0, 24],
      "Description": "The hour range this NPC is awake for."
    },
    "Attack": {
      "Value": "Root_Boss_Forklift_Fork_Attack",
      "Description": "The fork stab attack."
    },
    "TurnSingleAttack": {
      "Value": "Root_Boss_Forklift_Turn_Single",
      "Description": "The single turn sweep attack."
    },
    "TurnDoubleAttack": {
      "Value": "Root_Boss_Forklift_Turn_Double",
      "Description": "The double turn sweep attack."
    },
    "LeapAttack": {
      "Value": "Root_Boss_Forklift_Leap_Attack",
      "Description": "The leap attack to use when target is far away."
    },
    "AttackDistance": {
      "Value": 3.5,
      "Description": "The distance at which an NPC will execute attacks."
    },
    "AttackPauseRange": {
      "Value": [0.3, 0.6],
      "Description": "The minimum time before an NPC can execute a second attack."
    },
    "LeapDistance": {
      "Value": 6,
      "Description": "Distance at which the boss will leap instead of running."
    },
    "DesiredAttackDistanceRange": {
      "Value": [2, 3.5],
      "Description": "The distance within which the NPC wants to be from its target while attacking."
    },
    "CombatAttackPreDelay": {
      "Value": [0.1, 0.2],
      "Description": "The time delay range before the NPC performs an attack."
    },
    "CombatAttackPostDelay": {
      "Value": [0.2, 0.4],
      "Description": "The time delay range after the NPC performs an attack."
    },
    "CombatBehaviorDistance": {
      "Value": 20,
      "Description": "The distance within which to switch from chasing to combat movement."
    },
    "CombatRelativeTurnSpeed": {
      "Value": 0.6,
      "Description": "Modifier that decides turn speed difference in combat."
    },
    "CombatMovingRelativeSpeed": {
      "Value": 0.6,
      "Description": "Relative speed to use during combat movement."
    },
    "CombatBackwardsRelativeSpeed": {
      "Value": 0.35,
      "Description": "Relative speed when backing away from target."
    },
    "CombatBackOffAfterAttack": {
      "Value": false,
      "Description": "Whether to back off after performing an attack."
    },
    "CombatBackOffDistanceRange": {
      "Value": [2, 4],
      "Description": "How far to back off after performing an attack."
    },
    "CombatBackOffDurationRange": {
      "Value": [1.5, 2.5],
      "Description": "How long to back off for after performing an attack."
    },
    "CombatStrafingDurationRange": {
      "Value": [1, 3],
      "Description": "How long to strafe for."
    },
    "CombatStrafingFrequencyRange": {
      "Value": [2, 4],
      "Description": "How frequently to strafe."
    },
    "ChaseRelativeSpeed": {
      "Value": 0.8,
      "Description": "Relative chasing speed when pursuing a target."
    },
    "TargetRange": {
      "Value": 22,
      "Description": "Distance the target needs to be within to maintain priority."
    },
    "CombatFleeIfTooCloseDistance": {
      "Value": 0,
      "Description": "Distance for flee behavior."
    },
    "TargetSwitchTimer": {
      "Value": [3, 6],
      "Description": "Minimum time locked onto a single target."
    },
    "BlockAbility": {
      "Value": "",
      "Description": "The interaction to use for blocking."
    },
    "BlockProbability": {
      "Value": 0,
      "Description": "The probability this NPC will block."
    },
    "CombatStrafeWeight": {
      "Value": 2,
      "Description": "Weight for the combat strafing movement behavior."
    },
    "CombatDirectWeight": {
      "Value": 3,
      "Description": "Weight for the direct combat movement behavior."
    },
    "CombatAlwaysMovingWeight": {
      "Value": 4,
      "Description": "Weight for always-charge combat movement."
    },
    "ConfusedTimeRange": {
      "Value": [1, 2],
      "Description": "How long the NPC should act confused."
    },
    "SearchTimeRange": {
      "Value": [8, 12],
      "Description": "How long the NPC should search for lost target."
    },
    "LeashDistance": {
      "Value": 50,
      "Description": "The range after which an NPC will start to want to return."
    },
    "LeashMinPlayerDistance": {
      "Value": 10,
      "Description": "The minimum distance from the player before giving up on the chase."
    },
    "LeashTimer": {
      "Value": [5, 5],
      "Description": "How long the NPC must be too far before giving up."
    },
    "HardLeashDistance": {
      "Value": 80,
      "Description": "An absolute maximum from the leash position."
    },
    "DefaultPlayerAttitude": {
      "Value": "Hostile",
      "Description": "Default attitude towards players."
    },
    "DisableDamageGroups": {
      "Value": ["Self"],
      "Description": "Groups not to take damage from."
    },
    "DropList": {
      "Value": "Drop_Shotcave_Forklift_Boss",
      "Description": "Drop Items."
    },
    "UseCombatActionEvaluator": {
      "Value": false,
      "Description": "Whether to use the Combat Action Evaluator via an accompanying _CombatConfig. Replaces all other combat behavior but still uses movement properties."
    }
  },
  "Appearance": {
    "Compute": "Appearance"
  },
  "DropList": {
    "Compute": "DropList"
  },
  "DisableDamageGroups": {
    "Compute": "DisableDamageGroups"
  },
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": {
    "Compute": "DefaultPlayerAttitude"
  },
  "KnockbackScale": 0.1,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": {
        "Compute": "MaxSpeed"
      },
      "Gravity": 30,
      "RunThreshold": {
        "Compute": "RunThreshold"
      },
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "BusyStates": ["Combat", "Alerted", "Search"],
  "StateTransitions": [
    {
      "$Comment": "Always clear target when transitioning to Idle.",
      "States": [
        {
          "To": ["Idle"],
          "From": []
        }
      ],
      "Actions": [
        {
          "Type": "ReleaseTarget"
        },
        {
          "Type": "ResetInstructions"
        }
      ]
    },
    {
      "$Comment": "Always clear animation when moving from Alerted state.",
      "States": [
        {
          "To": [],
          "From": ["Alerted"]
        }
      ],
      "Actions": [
        {
          "Type": "SetFlag",
          "Name": "AnimationBlock",
          "SetTo": false
        }
      ]
    }
  ],
  "MaxHealth": {
    "Compute": "MaxHealth"
  },
  "InteractionVars": {
    "Melee_Damage": {
      "Interactions": [
        {
          "Parent": "NPC_Attack_Melee_Damage",
          "DamageCalculator": {
            "Type": "Absolute",
            "BaseDamage": {
              "Physical": 10
            },
            "RandomPercentageModifier": 0.1
          }
        }
      ]
    }
  },
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "=== IDLE STATE: Stay stationary, detect nearby players ===",
          "Sensor": {
            "Type": "State",
            "State": "Idle"
          },
          "Instructions": [
            {
              "$Comment": "Enter combat if taking damage.",
              "Reference": "Component_Instruction_Damage_Check",
              "Modify": {
                "_ExportStates": [
                  "Combat",
                  "Search.Confused"
                ],
                "AlertedRange": {
                  "Compute": "AlertedRange"
                }
              }
            },
            {
              "$Comment": "Check if there are any potential threats nearby.",
              "Sensor": {
                "Reference": "Component_Sensor_Standard_Detection",
                "Modify": {
                  "ViewRange": {
                    "Compute": "ViewRange"
                  },
                  "ViewSector": {
                    "Compute": "ViewSector"
                  },
                  "HearingRange": {
                    "Compute": "HearingRange"
                  },
                  "AbsoluteDetectionRange": {
                    "Compute": "AbsoluteDetectionRange"
                  },
                  "Attitudes": ["Hostile"]
                }
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Alerted"
                }
              ]
            },
            {
              "$Comment": "Boss stays stationary when idle.",
              "Sensor": {
                "Type": "Time",
                "Period": {
                  "Compute": "WakingPeriod"
                },
                "CheckDay": true
              },
              "Instructions": [
                {
                  "Reference": "Component_Instruction_Stationary_Idle"
                }
              ]
            }
          ]
        },
        {
          "$Comment": "=== ALERTED STATE: Boss noticed a player ===",
          "Sensor": {
            "Type": "State",
            "State": "Alerted"
          },
          "Instructions": [
            {
              "$Comment": "If target is in range, go to combat.",
              "Sensor": {
                "Reference": "Component_Sensor_Standard_Detection",
                "Modify": {
                  "ViewRange": {
                    "Compute": "AlertedRange"
                  },
                  "ViewSector": {
                    "Compute": "ViewSector"
                  },
                  "HearingRange": {
                    "Compute": "HearingRange"
                  },
                  "AbsoluteDetectionRange": {
                    "Compute": "AbsoluteDetectionRange"
                  },
                  "Attitudes": ["Hostile"]
                }
              },
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": {
                    "Compute": "AlertedTime"
                  }
                },
                {
                  "Type": "State",
                  "State": "Combat"
                }
              ]
            },
            {
              "$Comment": "Lost sight of the target.",
              "Actions": [
                {
                  "Type": "State",
                  "State": "Idle"
                }
              ]
            }
          ]
        },
        {
          "Enabled": { "Compute": "UseCombatActionEvaluator" },
          "$Comment": "=== COMBAT STATE (CAE): Combat Action Evaluator selects attacks intelligently ===",
          "Sensor": {
            "Type": "State",
            "State": "Combat"
          },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": {
                "Type": "State",
                "State": ".Message"
              },
              "Actions": [
                {
                  "Type": "Beacon",
                  "Message": "Under_Attack",
                  "TargetGroups": []
                },
                {
                  "Type": "State",
                  "State": ".Default"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Or",
                "Sensors": [
                  {
                    "Reference": "Component_Sensor_Standard_Detection",
                    "Modify": {
                      "ViewRange": { "Compute": "ViewRange" },
                      "ViewSector": { "Compute": "ViewSector" },
                      "HearingRange": { "Compute": "HearingRange" },
                      "AbsoluteDetectionRange": { "Compute": "AbsoluteDetectionRange" },
                      "Attitudes": ["Hostile"]
                    }
                  },
                  {
                    "Type": "HasHostileTargetMemory"
                  }
                ]
              },
              "Instructions": [
                {
                  "$Comment": "Store CAE target in marked target slot for leash/chase compatibility.",
                  "Continue": true,
                  "Sensor": {
                    "Type": "Or",
                    "Sensors": [
                      {
                        "Type": "CombatActionEvaluator",
                        "TargetInRange": true
                      },
                      {
                        "Type": "CombatActionEvaluator",
                        "TargetInRange": false
                      }
                    ]
                  },
                  "Actions": [
                    {
                      "Type": "SetMarkedTarget"
                    }
                  ]
                },
                {
                  "Continue": true,
                  "Sensor": {
                    "Type": "Damage",
                    "Combat": true
                  },
                  "Actions": [
                    {
                      "Type": "OverrideAttitude",
                      "Attitude": "Hostile",
                      "Duration": 60
                    },
                    {
                      "Type": "AddToHostileTargetMemory"
                    }
                  ]
                },
                {
                  "TreeMode": true,
                  "Sensor": {
                    "Type": "State",
                    "State": ".Default"
                  },
                  "Instructions": [
                    {
                      "$Comment": "CAE target in range - maintain distance and execute chosen ability.",
                      "Sensor": {
                        "Type": "CombatActionEvaluator",
                        "TargetInRange": true
                      },
                      "HeadMotion": {
                        "Type": "Aim",
                        "HitProbability": 0.95,
                        "Deflection": true,
                        "Spread": 0
                      },
                      "BodyMotion": {
                        "Type": "MaintainDistance",
                        "DesiredDistanceRange": { "Compute": "DesiredAttackDistanceRange" },
                        "MoveThreshold": 0.2,
                        "RelativeForwardsSpeed": { "Compute": "CombatMovingRelativeSpeed" },
                        "RelativeBackwardsSpeed": { "Compute": "CombatBackwardsRelativeSpeed" }
                      },
                      "Actions": [
                        {
                          "Type": "CombatAbility"
                        }
                      ]
                    }
                  ]
                },
                {
                  "TreeMode": true,
                  "Sensor": {
                    "Type": "State",
                    "State": ".Strafe",
                    "IgnoreMissingSetState": true
                  },
                  "Instructions": [
                    {
                      "$Comment": "CAE strafe substate - keep distance while applying strafe movement and combat abilities.",
                      "Sensor": {
                        "Type": "CombatActionEvaluator",
                        "TargetInRange": true
                      },
                      "HeadMotion": {
                        "Type": "Aim",
                        "HitProbability": 0.95,
                        "Deflection": true,
                        "Spread": 0
                      },
                      "BodyMotion": {
                        "Type": "MaintainDistance",
                        "DesiredDistanceRange": { "Compute": "DesiredAttackDistanceRange" },
                        "MoveThreshold": 0.2,
                        "StrafingDurationRange": { "Compute": "CombatStrafingDurationRange" },
                        "StrafingFrequencyRange": { "Compute": "CombatStrafingFrequencyRange" },
                        "RelativeForwardsSpeed": { "Compute": "CombatMovingRelativeSpeed" },
                        "RelativeBackwardsSpeed": { "Compute": "CombatBackwardsRelativeSpeed" }
                      },
                      "Actions": [
                        {
                          "Type": "CombatAbility"
                        }
                      ]
                    }
                  ]
                },
                {
                  "Reference": "Component_Instruction_Soft_Leash",
                  "Modify": {
                    "_ExportStates": ["ReturnHome"],
                    "LeashDistance": { "Compute": "LeashDistance" },
                    "LeashMinPlayerDistance": { "Compute": "LeashMinPlayerDistance" },
                    "LeashTimer": { "Compute": "LeashTimer" },
                    "HardLeashDistance": { "Compute": "HardLeashDistance" }
                  }
                },
                {
                  "Reference": "Component_Instruction_Intelligent_Chase",
                  "Modify": {
                    "_ExportStates": ["Search.Confused", "Search.Confused", "ReturnHome"],
                    "ViewRange": { "Compute": "AlertedRange" },
                    "HearingRange": { "Compute": "HearingRange" },
                    "RelativeSpeed": { "Compute": "ChaseRelativeSpeed" }
                  }
                }
              ]
            },
            {
              "Actions": [
                {
                  "Type": "State",
                  "State": "Search.Confused"
                }
              ]
            }
          ]
        },
        {
          "Enabled": { "Compute": "!UseCombatActionEvaluator" },
          "$Comment": "=== COMBAT STATE (Legacy): Random attack selection fallback ===",
          "Sensor": {
            "Type": "State",
            "State": "Combat"
          },
          "Instructions": [
            {
              "$Comment": "Send combat beacon when entering combat.",
              "Continue": true,
              "Sensor": {
                "Type": "State",
                "State": ".Message"
              },
              "Actions": [
                {
                  "Type": "Beacon",
                  "Message": "Under_Attack",
                  "TargetGroups": []
                },
                {
                  "Type": "State",
                  "State": ".Default"
                }
              ]
            },
            {
              "$Comment": "Escape combat if no hostile target can be detected and none remembered (e.g. all targets are ghost/dead).",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Not",
                    "Sensor": {
                      "Reference": "Component_Sensor_Standard_Detection",
                      "Modify": {
                        "ViewRange": { "Compute": "AlertedRange" },
                        "ViewSector": { "Compute": "ViewSector" },
                        "HearingRange": { "Compute": "HearingRange" },
                        "AbsoluteDetectionRange": { "Compute": "AbsoluteDetectionRange" },
                        "Attitudes": ["Hostile"]
                      }
                    }
                  },
                  {
                    "Type": "Not",
                    "Sensor": {
                      "Type": "HasHostileTargetMemory"
                    }
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Search.Confused"
                }
              ]
            },
            {
              "$Comment": "Chase substate: target is too far, run to them.",
              "Sensor": {
                "Type": "State",
                "State": ".Chase"
              },
              "Instructions": [
                {
                  "$Comment": "When target is in attack distance, go back to default combat.",
                  "Sensor": {
                    "Type": "Target",
                    "Range": {
                      "Compute": "AttackDistance"
                    },
                    "Filters": [
                      {
                        "Type": "LineOfSight"
                      }
                    ]
                  },
                  "Actions": [
                    {
                      "Type": "State",
                      "State": ".Default"
                    }
                  ]
                },
                {
                  "$Comment": "LEAP: use leap attack when target is 5+ blocks away.",
                  "Continue": true,
                  "Sensor": {
                    "Type": "And",
                    "Sensors": [
                      {
                        "Type": "Target",
                        "Range": {
                          "Compute": "LeapDistance"
                        }
                      },
                      {
                        "Type": "Not",
                        "Sensor": {
                          "Type": "Target",
                          "Range": 5
                        }
                      }
                    ]
                  },
                  "ActionsBlocking": false,
                  "Actions": [
                    {
                      "Type": "Attack",
                      "Attack": {
                        "Compute": "LeapAttack"
                      },
                      "AttackPauseRange": [0.45, 0.75]
                    }
                  ]
                },
                {
                  "$Comment": "Return home if too far from spawn.",
                  "Reference": "Component_Instruction_Soft_Leash",
                  "Modify": {
                    "_ExportStates": ["ReturnHome"],
                    "LeashDistance": {
                      "Compute": "LeashDistance"
                    },
                    "LeashMinPlayerDistance": {
                      "Compute": "LeashMinPlayerDistance"
                    },
                    "LeashTimer": {
                      "Compute": "LeashTimer"
                    },
                    "HardLeashDistance": {
                      "Compute": "HardLeashDistance"
                    }
                  }
                },
                {
                  "$Comment": "Chase the target.",
                  "Reference": "Component_Instruction_Intelligent_Chase",
                  "Modify": {
                    "_ExportStates": [
                      "Search.Confused",
                      "Search.Confused",
                      "ReturnHome"
                    ],
                    "ViewRange": {
                      "Compute": "AlertedRange"
                    },
                    "HearingRange": {
                      "Compute": "HearingRange"
                    },
                    "RelativeSpeed": {
                      "Compute": "ChaseRelativeSpeed"
                    }
                  }
                }
              ]
            },
            {
              "$Comment": "Retreat behavior if needed.",
              "Reference": "Component_Instruction_Combat_Retreat",
              "Modify": {
                "CombatFleeIfTooCloseDistance": {
                  "Compute": "CombatFleeIfTooCloseDistance"
                },
                "AttackDistance": {
                  "Compute": "AttackDistance"
                }
              }
            },
            {
              "$Comment": "Track damage sources for target switching.",
              "Continue": true,
              "Sensor": {
                "Type": "Damage",
                "Combat": true
              },
              "Actions": [
                {
                  "Type": "OverrideAttitude",
                  "Attitude": "Hostile",
                  "Duration": 60
                },
                {
                  "Type": "AddToHostileTargetMemory"
                }
              ]
            },
            {
              "$Comment": "Target swapping.",
              "Reference": "Component_Instruction_Combat_Target_Swap",
              "Modify": {
                "TargetSwitchTimer": {
                  "Compute": "TargetSwitchTimer"
                },
                "TargetRange": {
                  "Compute": "TargetRange"
                },
                "NextTargetRangeView": {
                  "Compute": "ViewRange"
                },
                "NextTargetRangeHearing": {
                  "Compute": "HearingRange"
                }
              }
            },
            {
              "$Comment": "LEAP in default combat: use leap for 5+ blocks.",
              "Continue": true,
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Target",
                    "Range": {
                      "Compute": "LeapDistance"
                    },
                    "Filters": [
                      {
                        "Type": "LineOfSight"
                      }
                    ]
                  },
                  {
                    "Type": "Not",
                    "Sensor": {
                      "Type": "Target",
                      "Range": 5
                    }
                  }
                ]
              },
              "ActionsBlocking": false,
              "Actions": [
                {
                  "Type": "Attack",
                  "Attack": {
                    "Compute": "LeapAttack"
                  },
                  "AttackPauseRange": [0.45, 0.75]
                }
              ]
            },
            {
              "$Comment": "Attack when target is within range - randomly picks between fork, turn single, turn double.",
              "Continue": true,
              "Type": "Random",
              "Sensor": {
                "Type": "Target",
                "Range": {
                  "Compute": "AttackDistance"
                },
                "Filters": [
                  {
                    "Type": "LineOfSight"
                  }
                ]
              },
              "Instructions": [
                {
                  "$Comment": "Fork stab attack.",
                  "Weight": 3,
                  "ActionsBlocking": true,
                  "Actions": [
                    {
                      "Type": "Timeout",
                      "Delay": {
                        "Compute": "CombatAttackPreDelay"
                      }
                    },
                    {
                      "Type": "Attack",
                      "Attack": {
                        "Compute": "Attack"
                      },
                      "AttackPauseRange": {
                        "Compute": "AttackPauseRange"
                      }
                    }
                  ]
                },
                {
                  "$Comment": "Single turn sweep.",
                  "Weight": 3,
                  "ActionsBlocking": true,
                  "Actions": [
                    {
                      "Type": "Timeout",
                      "Delay": {
                        "Compute": "CombatAttackPreDelay"
                      }
                    },
                    {
                      "Type": "Attack",
                      "Attack": {
                        "Compute": "TurnSingleAttack"
                      },
                      "AttackPauseRange": {
                        "Compute": "AttackPauseRange"
                      }
                    }
                  ]
                },
                {
                  "$Comment": "Double turn sweep.",
                  "Weight": 2,
                  "ActionsBlocking": true,
                  "Actions": [
                    {
                      "Type": "Timeout",
                      "Delay": {
                        "Compute": "CombatAttackPreDelay"
                      }
                    },
                    {
                      "Type": "Attack",
                      "Attack": {
                        "Compute": "TurnDoubleAttack"
                      },
                      "AttackPauseRange": [0.4, 0.7]
                    }
                  ]
                }
              ]
            },
            {
              "$Comment": "If target can't be reached, wait then chase.",
              "Continue": true,
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Not",
                    "Sensor": {
                      "Type": "Target",
                      "Range": {
                        "Compute": "AttackDistance"
                      }
                    }
                  },
                  {
                    "Type": "Or",
                    "Sensors": [
                      {
                        "Type": "Nav",
                        "NavStates": ["Defer"],
                        "ThrottleDuration": 3
                      },
                      {
                        "Type": "Target",
                        "Range": {

{
  "Type": "Abstract",
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Hostile",
  "AttitudeGroup": { "Compute": "AttitudeGroup" },
  "BusyStates": [ "Chase", "Search", "ReturnHome" ],
  "Parameters": {
    "Appearance": {
      "Value": "Kweebec_DeadWood",
      "Description": "Model to be used"
    },
    "IdleMotionComponent": {
      "Value": "Component_Instruction_Intelligent_Idle_Motion_Wander",
      "Description": "The component that controls how the NPC moves during idle state"
    },
    "ViewRange": {
      "Value": 30,
      "Description": "View range"
    },
    "ViewSector": {
      "Value": 280,
      "Description": "View sector"
    },
    "HearingRange": {
      "Value": 22,
      "Description": "Hearing range"
    },
    "AbsoluteDetectionRange": {
      "Value": 8,
      "Description": "Guaranteed detection distance"
    },
    "AlertedRange": {
      "Value": 54,
      "Description": "Detection range while in combat/search"
    },
    "LeashDistance": {
      "Value": 60,
      "Description": "Distance before returning to spawn"
    },
    "LeashMinPlayerDistance": {
      "Value": 7,
      "Description": "Minimum player distance before leash can force return"
    },
    "LeashTimer": {
      "Value": [8, 8],
      "Description": "Time spent out of leash range before returning"
    },
    "HardLeashDistance": {
      "Value": 220,
      "Description": "Absolute max distance from spawn"
    },
    "DropList": {
      "Value": "Drop_Shotcave_DeadWood_Combat",
      "Description": "Drop items"
    },
    "MaxSpeed": {
      "Value": 7.2,
      "Description": "Maximum walking speed"
    },
    "RelativeChaseSpeed": {
      "Value": 0.92,
      "Description": "Relative chase speed"
    },
    "Weapons": {
      "Value": [],
      "TypeHint": "String",
      "Description": "NPC weapon list (empty = fists)"
    },
    "DefaultHotbarSlot": {
      "Value": 0,
      "Description": "Default hotbar slot to equip"
    },
    "AttackSequence": {
      "Value": "Component_Instruction_Attack_Sequence_Temp",
      "Description": "Melee attack sequence"
    },
    "AttackDistance": {
      "Value": 1.5,
      "Description": "Distance at which attacks are executed"
    },
    "TargetGroups": {
      "Value": ["Kweebec_DeadWood"],
      "Description": "Beacon target groups"
    },
    "DisableDamageGroups": {
      "Value": ["Self", "Kweebec_DeadWood"],
      "Description": "Groups not to take damage from"
    },
    "AttitudeGroup": {
      "Value": "Kweebec_DeadWood",
      "Description": "Attitude group"
    },
    "CombatRelativeTurnSpeed": {
      "Value": 1.9,
      "Description": "Turn speed modifier in combat"
    },
    "MaxHealth": {
      "Value": 88,
      "Description": "Max health for the NPC"
    },
    "IsMemory": {
      "Value": true,
      "Description": "Defines if the NPC is a memory"
    },
    "MemoriesCategory": {
      "Value": "Kweebec_DeadWood",
      "Description": "Defines the memory category"
    },
    "MemoriesNameOverride": {
      "Value": "Kweebec_DeadWood_Rootling",
      "Description": "Memory name override"
    },
    "NameTranslationKey": {
      "Value": "bettermobs.npcRoles.Kweebec_DeadWood_Rootling.name",
      "Description": "Translation key for NPC name display"
    }
  },
  "IsMemory": { "Compute": "IsMemory" },
  "MemoriesCategory": { "Compute": "MemoriesCategory" },
  "MemoriesNameOverride": { "Compute": "MemoriesNameOverride" },
  "Appearance": { "Compute": "Appearance" },
  "DropList": { "Compute": "DropList" },
  "DisableDamageGroups": { "Compute": "DisableDamageGroups" },
  "HotbarItems": { "Compute": "Weapons" },
  "HotbarSize": 3,
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": { "Compute": "MaxSpeed" },
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10,
      "MinJumpHeight": 0.8
    }
  ],
  "MaxHealth": { "Compute": "MaxHealth" },
  "Instructions": [
    {
      "Continue": true,
      "Sensor": {
        "Type": "Any",
        "Once": true
      },
      "Actions": [
        {
          "Type": "Inventory",
          "Operation": "EquipHotbar",
          "UseTarget": false,
          "Slot": { "Compute": "DefaultHotbarSlot" }
        }
      ]
    },
    {
      "Continue": true,
      "Sensor": {
        "Type": "Beacon",
        "Message": "KweebecDeadWood_EnemyFound",
        "TargetSlot": "LockedTarget",
        "Range": { "Compute": "HearingRange * 2" }
      },
      "Actions": [
        {
          "Type": "State",
          "State": "Chase"
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Idle"
      },
      "Instructions": [
        {
          "Reference": "Component_Instruction_Damage_Check",
          "Modify": {
            "_ExportStates": ["Chase", "Search"],
            "AlertedRange": { "Compute": "AlertedRange" }
          }
        },
        {
          "Sensor": {
            "Reference": "Component_Sensor_Standard_Detection",
            "Modify": {
              "ViewRange": { "Compute": "ViewRange" },
              "ViewSector": { "Compute": "ViewSector" },
              "HearingRange": { "Compute": "HearingRange" },
              "AbsoluteDetectionRange": { "Compute": "AbsoluteDetectionRange" },
              "Attitudes": ["Hostile"]
            }
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": { "Compute": "HearingRange * 2" },
              "Message": "KweebecDeadWood_EnemyFound",
              "TargetGroups": { "Compute": "TargetGroups" },
              "SendTargetSlot": "LockedTarget"
            },
            {
              "Type": "State",
              "State": "Chase"
            }
          ]
        },
        {
          "Reference": { "Compute": "IdleMotionComponent" },
          "Interfaces": ["Hytale.Instruction.Intelligent.Idle.Motion"]
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Chase"
      },
      "Instructions": [
        {
          "Continue": true,
          "Sensor": {
            "Type": "Any",
            "Once": true
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": { "Compute": "HearingRange * 2" },
              "Message": "KweebecDeadWood_EnemyFound",
              "TargetGroups": { "Compute": "TargetGroups" },
              "SendTargetSlot": "LockedTarget"
            }
          ]
        },
        {
          "$Comment": "Switch target to whoever is attacking us and mark them as hostile.",
          "Continue": true,
          "Sensor": {
            "Type": "Damage",
            "Combat": true,
            "TargetSlot": "LockedTarget"
          },
          "Actions": [
            {
              "Type": "OverrideAttitude",
              "Attitude": "Hostile",
              "Duration": 60
            },
            {
              "Type": "AddToHostileTargetMemory"
            }
          ]
        },
        {
          "$Comment": "Only continue combat if a valid hostile target can be detected or is remembered. Ghost/dead players with IGNORE attitude are filtered out by the attitude-aware detection sensor.",
          "Sensor": {
            "Type": "Or",
            "Sensors": [
              {
                "Reference": "Component_Sensor_Standard_Detection",
                "Modify": {
                  "ViewRange": { "Compute": "AlertedRange" },
                  "ViewSector": { "Compute": "ViewSector" },
                  "HearingRange": { "Compute": "HearingRange" },
                  "AbsoluteDetectionRange": { "Compute": "AbsoluteDetectionRange" },
                  "Attitudes": ["Hostile"]
                }
              },
              {
                "Type": "HasHostileTargetMemory"
              }
            ]
          },
          "Instructions": [
            {
              "Reference": "Component_Instruction_Clear_Status_Animation"
            },
            {
              "Reference": "Component_Instruction_Target_Adjusted_Attack_Melee",
              "Modify": {
                "TargetSwitchTimer": [2, 4],
                "AttackSequence": { "Compute": "AttackSequence" },
                "AttackDistance": { "Compute": "AttackDistance" },
                "TargetRange": 4,
                "CombatRelativeTurnSpeed": { "Compute": "CombatRelativeTurnSpeed" }
              }
            },
            {
              "Reference": "Component_Instruction_Soft_Leash",
              "Modify": {
                "_ExportStates": ["ReturnHome"],
                "LeashDistance": { "Compute": "LeashDistance" },
                "LeashMinPlayerDistance": { "Compute": "LeashMinPlayerDistance" },
                "LeashTimer": { "Compute": "LeashTimer" },
                "HardLeashDistance": { "Compute": "HardLeashDistance" }
              }
            },
            {
              "Reference": "Component_Instruction_Intelligent_Chase",
              "Modify": {
                "_ExportStates": ["Search", "ReturnHome", "ReturnHome"],
                "ViewRange": { "Compute": "AlertedRange" },
                "HearingRange": { "Compute": "HearingRange" },
                "RelativeSpeed": { "Compute": "RelativeChaseSpeed" }
              }
            }
          ]
        },
        {
          "$Comment": "No valid hostile target found (ghost/dead/gone) - go to search.",
          "Actions": [
            {
              "Type": "State",
              "State": "Search"
            }
          ]
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "Search"
      },
      "Instructions": [
        {
          "$Comment": "Re-enter chase if attacked during search.",
          "Sensor": {
            "Type": "Damage",
            "Combat": true,
            "TargetSlot": "LockedTarget"
          },
          "Actions": [
            {
              "Type": "AddToHostileTargetMemory"
            },
            {
              "Type": "State",
              "State": "Chase"
            }
          ]
        },
        {
          "Continue": true,
          "Sensor": {
            "Type": "Any",
            "Once": true
          },
          "Actions": [
            {
              "Type": "Beacon",
              "Range": { "Compute": "HearingRange * 2" },
              "Message": "KweebecDeadWood_EnemyFound",
              "TargetGroups": { "Compute": "TargetGroups" },
              "SendTargetSlot": "LockedTarget"
            }
          ]
        },
        {
          "Reference": "Component_Instruction_Generic_Search",
          "Modify": {
            "_ExportStates": ["Chase", "Chase", "Search", "Idle"],
            "ViewRange": { "Compute": "ViewRange" },
            "ViewSector": { "Compute": "ViewSector" },
            "HearingRange": { "Compute": "HearingRange" }
          }
        }
      ]
    },
    {
      "Sensor": {
        "Type": "State",
        "State": "ReturnHome"
      },
      "Instructions": [
        {
          "Sensor": {
            "Type": "Leash",
            "Range": { "Compute": "LeashDistance * 0.3" }
          },
          "BodyMotion": {
            "Type": "Seek",
            "SlowDownDistance": 1,
            "StopDistance": 0.5,
            "RelativeSpeed": 1,
            "UsePathfinder": true
          }
        },
        {
          "Actions": [
            {
              "Type": "State",
              "State": "Idle"
            }
          ]
        }
      ]
    }
  ],
  "NameTranslationKey": { "Compute": "NameTranslationKey" }
}
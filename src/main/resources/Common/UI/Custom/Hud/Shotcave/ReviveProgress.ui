// ─────────────────────────────────────────────
//  Shotcave — Revive Progress HUD
//  Shown to alive players while reviving a teammate
// ─────────────────────────────────────────────

@DimText = #6b7d94;
@BrightText = #e8ecf0;
@PanelBg = #0c0f14(0.82);
@BarBg = #1e293b;
@BarFill = #22c55e;
@ReviveGreen = #a9f5b3;

Group #ReviveProgressRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;
  Visible: false;

  // ── Bottom-center panel ──
  Group #ReviveProgressAnchor {
    Anchor: (Left: 0, Right: 0, Bottom: 180, Height: 60);
    LayoutMode: Middle;

    Group #ReviveProgressPanel {
      Anchor: (Width: 220, Height: 50);
      Background: @PanelBg;
      LayoutMode: Top;
      Padding: (Horizontal: 14, Vertical: 8);

      // ── Label ──
      Label #ReviveLabel {
        Text: "Reviving...";
        Anchor: (Height: 16);
        Style: LabelStyle(
          FontSize: 11,
          TextColor: @ReviveGreen,
          RenderBold: true,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      // ── Progress bar background ──
      Group #ReviveBarBg {
        Anchor: (Height: 10, Top: 4, Left: 0, Right: 0);
        Background: @BarBg;

        // ── Progress bar fill ──
        Group #ReviveBarFill {
          Anchor: (Left: 0, Top: 0, Width: 0, Height: 10);
          Background: @BarFill;
        }
      }

      // ── Time text ──
      Label #ReviveTimeLabel {
        Text: "0.0 / 5.0s";
        Anchor: (Height: 14, Top: 2);
        Style: LabelStyle(
          FontSize: 10,
          TextColor: @DimText,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }
    }
  }
}

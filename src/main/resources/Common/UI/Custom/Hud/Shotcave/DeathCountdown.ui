// ─────────────────────────────────────────────
//  Shotcave — Death Countdown HUD
//  Shown to dead players during the 30s revive window
// ─────────────────────────────────────────────

@DimText = #6b7d94;
@BrightText = #e8ecf0;
@PanelBg = #0c0f14(0.82);
@DeadRed = #ef4444;
@GhostGray = #9ca3af;

Group #DeathCountdownRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;
  Visible: false;

  // ── Centered panel ──
  Group #DeathCountdownAnchor {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: Middle;

    Group #DeathCountdownPanel {
      Anchor: (Width: 260, Height: 80);
      Background: @PanelBg;
      LayoutMode: Top;
      Padding: (Horizontal: 16, Vertical: 10);

      // ── Title ──
      Label #DeathTitleLabel {
        Text: "YOU DIED";
        Anchor: (Height: 24);
        Style: LabelStyle(
          FontSize: 16,
          TextColor: @DeadRed,
          RenderBold: true,
          RenderUppercase: true,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      // ── Countdown text ──
      Label #DeathCountdownLabel {
        Text: "Revive window: 30s";
        Anchor: (Height: 20, Top: 4);
        Style: LabelStyle(
          FontSize: 13,
          TextColor: @BrightText,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      // ── Hint ──
      Label #DeathHintLabel {
        Text: "Teammates can crouch near you to revive";
        Anchor: (Height: 16, Top: 2);
        Style: LabelStyle(
          FontSize: 10,
          TextColor: @DimText,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }
    }
  }
}

// ─────────────────────────────────────────────
//  Shotcave — Crate Pickup HUD
//  Shows nearby F-key loot: weapon name with
//  rarity color, effect, collect prompt, and
//  an expandable details panel on crouch.
// ─────────────────────────────────────────────

@DimText = #8a9bb0;
@BrightText = #e8ecf0;
@AccentGold = #f0c050;
@PanelBg = #0c0f14(0.85);
@KeyBg = #2a3040;
@ModGreen = #3e9049;
@SepColor = #1e2535;

@CrateStatLabelStyle = LabelStyle(FontSize: 12, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center);
@CrateStatValueStyle = LabelStyle(FontSize: 12, TextColor: @BrightText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
@CrateStatModStyle = LabelStyle(FontSize: 12, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center);
@CrateModSlotStyle = LabelStyle(FontSize: 11, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center);

Group #CratePickupHudRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;

  // ── Compact wrapper (when NOT crouching) ──
  Group #CratePickupCompactWrapper {
    Anchor: (Bottom: 120, Left: 0, Right: 0, Height: 120);
    LayoutMode: Center;
    Visible: false;

    Group #CratePickupCompact {
      Anchor: (Width: 310, Height: 100);
      Background: @PanelBg;
      LayoutMode: Left;
      Padding: (Horizontal: 0, Vertical: 0);

      Group #CratePickupAccentCompact {
        Anchor: (Width: 4, Top: 0, Bottom: 0, Left: 0);
        Background: @DimText;
      }

      Group {
        Anchor: (Left: 12, Right: 10, Top: 10, Bottom: 10);
        LayoutMode: Top;

        Group {
          Anchor: (Height: 24);
          LayoutMode: Left;
          AssetImage #CratePickupIconCompact { Anchor: (Width: 22, Height: 22, Top: 0); Visible: false; }
          Label #CratePickupItemNameCompact {
            Text: "Item"; Anchor: (Height: 24, Left: 4);
            Style: LabelStyle(FontName: "Secondary", FontSize: 14, TextColor: @BrightText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 11);
          }
          Label #CratePickupQuantityCompact { Text: ""; Anchor: (Height: 24, Left: 4); Visible: false; Style: LabelStyle(FontSize: 12, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        }

        Label #CratePickupEffectLabelCompact {
          Text: ""; Anchor: (Height: 18, Top: 1); Visible: false;
          Style: LabelStyle(FontSize: 11, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center);
        }

        Group {
          Anchor: (Height: 24, Top: 3);
          LayoutMode: Left;
          Group #CratePickupKeyHintCompact {
            Anchor: (Width: 24, Height: 22, Top: 0); Background: @KeyBg; Visible: false; LayoutMode: Center;
            Label { Text: "F"; Anchor: (Width: 24, Height: 22); Style: LabelStyle(FontName: "Secondary", FontSize: 13, TextColor: @AccentGold, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
          }
          Label #CratePickupCollectLabelCompact { Text: "Collect"; Anchor: (Height: 22, Left: 6, Top: 0); Visible: false; Style: LabelStyle(FontSize: 12, TextColor: @DimText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center); }
          Label #CratePickupCrouchHint { Text: ""; Anchor: (Height: 22, Left: 12, Top: 0); Visible: false; Style: LabelStyle(FontSize: 11, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        }
      }
    }
  }

  // ── Expanded wrapper (when crouching) ──
  Group #CratePickupExpandedWrapper {
    Anchor: (Bottom: 140, Left: 0, Right: 0, Height: 550);
    LayoutMode: Center;
    Visible: false;

    // ── Vertical column for bottom-alignment ──
    Group {
      Anchor: (Width: 330, Top: 0, Bottom: 0);
      LayoutMode: Top;

      // ── Spacer: pushes panel to bottom ──
      Group { FlexWeight: 1; }

      // ── Visible panel — accent color BG with dark content overlaid ──
      Group #CratePickupExpanded {
        LayoutMode: Top;
        Background: @DimText;

        Group {
          Anchor: (Left: 4);
          LayoutMode: Top;
          Padding: (Left: 8, Right: 10, Top: 10, Bottom: 10);
          Background: @PanelBg;

        Group {
          Anchor: (Height: 24);
          LayoutMode: Left;
          AssetImage #CratePickupIconExpanded { Anchor: (Width: 22, Height: 22, Top: 0); Visible: false; }
          Label #CratePickupItemNameExpanded {
            Text: "Item"; Anchor: (Height: 24, Left: 4);
            Style: LabelStyle(FontName: "Secondary", FontSize: 14, TextColor: @BrightText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 11);
          }
          Label #CratePickupQuantityExpanded { Text: ""; Anchor: (Height: 24, Left: 4); Visible: false; Style: LabelStyle(FontSize: 12, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        }

        Label #CratePickupEffectLabelExpanded {
          Text: ""; Anchor: (Height: 18, Top: 1); Visible: false;
          Style: LabelStyle(FontSize: 11, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center);
        }

        Group {
          Anchor: (Height: 24, Top: 3);
          LayoutMode: Left;
          Group #CratePickupKeyHintExpanded {
            Anchor: (Width: 24, Height: 22, Top: 0); Background: @KeyBg; Visible: false; LayoutMode: Center;
            Label { Text: "F"; Anchor: (Width: 24, Height: 22); Style: LabelStyle(FontName: "Secondary", FontSize: 13, TextColor: @AccentGold, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); }
          }
          Label #CratePickupCollectLabelExpanded { Text: "Collect"; Anchor: (Height: 22, Left: 6, Top: 0); Visible: false; Style: LabelStyle(FontSize: 12, TextColor: @DimText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center); }
        }

        // ── Details panel ──
        Group #CratePickupDetails {
          Anchor: (Top: 6);
          LayoutMode: Top;

          // ── Separator ──
          Group { Anchor: (Height: 1, Left: 0, Right: 0); Background: @SepColor; }

          Group #CratePickupStatRow0 { Anchor: (Height: 20, Top: 6); LayoutMode: Left; Label #CratePickupStatLabel0 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase0 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod0 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow1 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel1 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase1 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod1 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow2 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel2 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase2 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod2 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow3 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel3 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase3 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod3 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow4 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel4 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase4 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod4 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow5 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel5 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase5 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod5 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }
          Group #CratePickupStatRow6 { Anchor: (Height: 20, Top: 2); LayoutMode: Left; Label #CratePickupStatLabel6 { Text: ""; Anchor: (Width: 95, Height: 20); Style: @CrateStatLabelStyle; } Label #CratePickupStatBase6 { Text: ""; Anchor: (Width: 55, Height: 20, Left: 4); Style: @CrateStatValueStyle; } Label #CratePickupStatMod6 { Text: ""; Anchor: (Height: 20, Left: 2); Style: @CrateStatModStyle; } }

          // ── Modifier section ──
          Group #CratePickupModSeparator { Anchor: (Height: 1, Top: 6, Left: 0, Right: 0); Background: @SepColor; }
          Label #CratePickupMod0 { Text: ""; Anchor: (Height: 18, Top: 4); Style: @CrateModSlotStyle; }
          Label #CratePickupMod1 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @CrateModSlotStyle; }
          Label #CratePickupMod2 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @CrateModSlotStyle; }
          Label #CratePickupMod3 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @CrateModSlotStyle; }
          Label #CratePickupMod4 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @CrateModSlotStyle; }
        }
      }
      }
    }
  }
}

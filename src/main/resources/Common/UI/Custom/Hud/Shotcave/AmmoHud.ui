Group #ShotcaveHudRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);

  Group #ShotcaveAmmoRoot {
    LayoutMode: Right;
    Anchor: (Width: 300, Height: 74, Top: 40, Right: 40);
    Background: #0f1014(0.72);
    Padding: (Horizontal: 16, Vertical: 10);
    Visible: false;

    Label #ShotcaveAmmoValue {
      Text: "0";
      Anchor: (Height: 54);
      Style: LabelStyle(FontName: "Mono", FontSize: 40, TextColor: #f8f8f8, VerticalAlignment: Center);
    }

    Label {
      Text: "/";
      Anchor: (Height: 54, Left: 8, Right: 8);
      Style: LabelStyle(FontName: "Mono", FontSize: 28, TextColor: #b7b7b7, VerticalAlignment: Center);
    }

    Label #ShotcaveMaxAmmoValue {
      Text: "0";
      Anchor: (Height: 54);
      Style: LabelStyle(FontName: "Mono", FontSize: 28, TextColor: #cfcfcf, VerticalAlignment: Center);
    }
  }
}

// ─────────────────────────────────────────────
//  Shotcave — Weapon Info HUD
//  Expanded weapon card with rarity, stats, modifiers, and ammo bar
// ─────────────────────────────────────────────

@DimText = #6b7d94;
@BrightText = #e8ecf0;
@AmmoFull = #7aa8d4;
@BarTrack = #1a1f2a;
@PanelBg = #0c0f14(0.82);
@ModGreen = #3e9049;
@AccentDefault = #6b7d94;

Group #ShotcaveHudRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;

  // ── Main container — bottom-left ──
  Group #ShotcaveAmmoRoot {
    Anchor: (Width: 220, Height: 310, Bottom: 74, Left: 24);
    Background: @PanelBg;
    Visible: false;

    // ── Rarity accent bar (left edge) ──
    Group #ShotcaveRarityAccent {
      Anchor: (Width: 3, Top: 0, Bottom: 0, Left: 0);
      Background: @AccentDefault;
    }

    // ── Content area (to the right of accent bar) ──
    Group {
      Anchor: (Top: 0, Bottom: 0, Left: 3, Right: 0);
      LayoutMode: Top;
      Padding: (Horizontal: 12, Vertical: 8);

      // ── Weapon title ──
      Label #ShotcaveWeaponTitle {
        Text: "WEAPON";
        Anchor: (Height: 18);
        Style: LabelStyle(
          FontSize: 11,
          TextColor: @BrightText,
          RenderUppercase: true,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      // ── Category label ──
      Label #ShotcaveCategoryLabel {
        Text: "LASER";
        Anchor: (Height: 14, Top: 1);
        Style: LabelStyle(
          FontSize: 9,
          TextColor: @DimText,
          RenderUppercase: true,
          HorizontalAlignment: Start,
          VerticalAlignment: Center
        );
      }

      // ── Separator ──
      Group {
        Anchor: (Height: 1, Top: 6, Left: 0, Right: 0);
        Background: #1a1f2a;
      }

      // ── Stat rows ──

      // Damage
      Group {
        Anchor: (Height: 16, Top: 4);
        LayoutMode: Left;
        Label #ShotcaveStatDamageLabel { Text: "Damage"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatDamageBase { Text: "0"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatDamageMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Speed
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatSpeedLabel { Text: "Speed"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatSpeedBase { Text: "0s"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatSpeedMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Range
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatRangeLabel { Text: "Range"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatRangeBase { Text: "0"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatRangeMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Precision
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatPrecisionLabel { Text: "Precision"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatPrecisionBase { Text: "100%"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatPrecisionMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Knockback
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatKnockbackLabel { Text: "Knockback"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatKnockbackBase { Text: "0"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatKnockbackMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Max Ammo
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatMaxAmmoLabel { Text: "Max Ammo"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatMaxAmmoBase { Text: "0"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatMaxAmmoMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Pellets
      Group {
        Anchor: (Height: 16, Top: 1);
        LayoutMode: Left;
        Label #ShotcaveStatPelletsLabel { Text: "Pellets"; Anchor: (Width: 80, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatPelletsBase { Text: "1"; Anchor: (Width: 40, Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @BrightText, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #ShotcaveStatPelletsMod { Text: ""; Anchor: (Height: 16); Style: LabelStyle(FontSize: 9, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // Modifiers summary
      Label #ShotcaveModifiersLabel {
        Text: "";
        Anchor: (Height: 48, Top: 4);
        Visible: false;
        Style: LabelStyle(
          FontSize: 8,
          TextColor: @ModGreen,
          HorizontalAlignment: Start,
          VerticalAlignment: Start
        );
      }

      // ── Separator ──
      Group {
        Anchor: (Height: 1, Top: 6, Left: 0, Right: 0);
        Background: #1a1f2a;
      }

      // ── Ammo counter row ──
      Group {
        Anchor: (Height: 22, Top: 4);
        LayoutMode: Left;

        Label #ShotcaveAmmoValue {
          Text: "0";
          Anchor: (Height: 22);
          Style: LabelStyle(
            FontName: "Mono",
            FontSize: 18,
            TextColor: @BrightText,
            VerticalAlignment: Center,
            HorizontalAlignment: Start
          );
        }

        Label {
          Text: "/";
          Anchor: (Height: 22, Left: 3, Right: 2);
          Style: LabelStyle(
            FontName: "Mono",
            FontSize: 12,
            TextColor: @DimText,
            VerticalAlignment: Center,
            HorizontalAlignment: Center
          );
        }

        Label #ShotcaveMaxAmmoValue {
          Text: "0";
          Anchor: (Height: 22);
          Style: LabelStyle(
            FontName: "Mono",
            FontSize: 12,
            TextColor: @DimText,
            VerticalAlignment: Center,
            HorizontalAlignment: Start
          );
        }
      }

      // ── Ammo bar ──
      Group #ShotcaveAmmoBarTrack {
        Anchor: (Height: 4, Top: 2, Left: 0, Right: 0);
        Background: @BarTrack;

        Group #ShotcaveAmmoBarFill {
          Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
          Background: @AmmoFull;
        }
      }
    }
  }
}

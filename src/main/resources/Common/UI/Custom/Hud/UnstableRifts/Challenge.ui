// ─────────────────────────────────────────────
//  UnstableRifts — Challenge Objectives HUD
//  Displays active challenge objectives with completion status
// ─────────────────────────────────────────────

@PanelBg = #0c0f14(0.78);
@TitleColor = #d9c18a;
@LabelColor = #8fa4b8;
@CompletedColor = #5eb85e;
@IncompleteColor = #e8ecf0;

Group #ChallengeRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;

  // ── Left-side panel ──
  Group #ChallengeAnchor {
    Anchor: (Width: 240, Left: 12, Top: 0, Bottom: 0);
    LayoutMode: Middle;

    Group #ChallengePanel {
      Anchor: (Width: 240, Height: 160);
      Background: @PanelBg;
      LayoutMode: Top;
      Padding: (Horizontal: 12, Vertical: 8);
      Visible: true;

      // ── Title ──
      Label #ChallengeTitleLabel {
        Text: "CHALLENGES";
        Anchor: (Height: 22);
        Style: LabelStyle(
          FontSize: 13,
          TextColor: @TitleColor,
          RenderBold: true,
          RenderUppercase: true,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      // ── Objective rows (up to 5) ──
      Group #Obj0 {
        Anchor: (Height: 20, Top: 4);
        LayoutMode: Left;
        Label #Obj0Check { Text: "[ ]"; Anchor: (Width: 24, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Center, VerticalAlignment: Center); }
        Label #Obj0Text { Text: "—"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }
      Group #Obj1 {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Visible: false;
        Label #Obj1Check { Text: "[ ]"; Anchor: (Width: 24, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Center, VerticalAlignment: Center); }
        Label #Obj1Text { Text: "—"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }
      Group #Obj2 {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Visible: false;
        Label #Obj2Check { Text: "[ ]"; Anchor: (Width: 24, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Center, VerticalAlignment: Center); }
        Label #Obj2Text { Text: "—"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }
      Group #Obj3 {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Visible: false;
        Label #Obj3Check { Text: "[ ]"; Anchor: (Width: 24, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Center, VerticalAlignment: Center); }
        Label #Obj3Text { Text: "—"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }
      Group #Obj4 {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Visible: false;
        Label #Obj4Check { Text: "[ ]"; Anchor: (Width: 24, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Center, VerticalAlignment: Center); }
        Label #Obj4Text { Text: "—"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @IncompleteColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }

      // ── Mob counter (shown for MOB_CLEAR) ──
      Group #MobCounterRow {
        Anchor: (Height: 20, Top: 4);
        LayoutMode: Left;
        Visible: false;
        Label { Text: "Enemies remaining:"; Anchor: (Width: 150, Height: 20); Style: LabelStyle(FontSize: 11, TextColor: @LabelColor, HorizontalAlignment: Start, VerticalAlignment: Center); }
        Label #MobCounterLabel { Text: "0"; Anchor: (Height: 20); Style: LabelStyle(FontSize: 12, TextColor: @IncompleteColor, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center); }
      }
    }
  }
}

// ─────────────────────────────────────────────
//  UnstableRifts — Weapon Info HUD
//  Weapon card with rarity accent, stats, modifiers, and ammo bar
// ─────────────────────────────────────────────

@DimText = #8a9bb0;
@BrightText = #e8ecf0;
@AmmoFull = #7aa8d4;
@BarTrack = #1a1f2a;
@PanelBg = #0c0f14(0.85);
@ModGreen = #3e9049;
@AccentDefault = #6b7d94;
@SepColor = #1e2535;

@StatLabelStyle = LabelStyle(FontSize: 12, TextColor: @DimText, HorizontalAlignment: Start, VerticalAlignment: Center);
@StatValueStyle = LabelStyle(FontSize: 12, TextColor: @BrightText, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
@StatModStyle = LabelStyle(FontSize: 12, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center);
@ModSlotStyle = LabelStyle(FontSize: 11, TextColor: @ModGreen, HorizontalAlignment: Start, VerticalAlignment: Center);

Group #UnstableRiftsHudRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
  HitTestVisible: false;

  // ── Invisible wrapper — bottom-left, fixed max height ──
  Group #UnstableRiftsAmmoRoot {
    Anchor: (Width: 270, Height: 420, Bottom: 74, Left: 24);
    LayoutMode: Top;
    Visible: false;

    // ── Spacer: absorbs remaining space, pushes panel to bottom ──
    Group { FlexWeight: 1; }

    // ── Visible panel — accent color background, content overlaid ──
    Group #UnstableRiftsAmmoPanel {
      LayoutMode: Top;
      Background: @AccentDefault;

      // ── Content area (3px left offset reveals accent strip) ──
      Group {
        Anchor: (Left: 3);
        LayoutMode: Top;
        Padding: (Horizontal: 14, Vertical: 10);
        Background: @PanelBg;

      // ── Weapon title ──
      Label #UnstableRiftsWeaponTitle {
        Text: "WEAPON";
        Anchor: (Height: 24);
        Style: LabelStyle(
          FontName: "Secondary",
          FontSize: 15,
          TextColor: @BrightText,
          RenderUppercase: true,
          RenderBold: true,
          LetterSpacing: 0.5,
          HorizontalAlignment: Start,
          VerticalAlignment: Center,
          ShrinkTextToFit: true,
          MinShrinkTextToFitFontSize: 11
        );
      }

      // ── Subtitle: rarity + category + effect ──
      Group #UnstableRiftsCategoryRow {
        Anchor: (Height: 18, Top: 1);
        LayoutMode: Left;

        Label #UnstableRiftsCategoryLabel {
          Text: "LASER";
          Anchor: (Height: 18);
          Style: LabelStyle(
            FontSize: 11,
            TextColor: @DimText,
            RenderUppercase: true,
            HorizontalAlignment: Start,
            VerticalAlignment: Center,
            LetterSpacing: 0.3
          );
        }

        Label #UnstableRiftsEffectLabel {
          Text: "";
          Anchor: (Height: 18, Left: 6);
          Visible: false;
          Style: LabelStyle(
            FontSize: 11,
            HorizontalAlignment: Start,
            VerticalAlignment: Center
          );
        }
      }

      // ── Stats section (visible when crouching) ──
      Group #UnstableRiftsStatsSection {
        LayoutMode: Top;

      // ── Separator ──
      Group { Anchor: (Height: 1, Top: 8, Left: 0, Right: 0); Background: @SepColor; }

      // ── Stat rows ──

      Group #UnstableRiftsStatDamageRow {
        Anchor: (Height: 20, Top: 6);
        LayoutMode: Left;
        Label #UnstableRiftsStatDamageLabel { Text: "Damage"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatDamageBase { Text: "0"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatDamageMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatSpeedRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatSpeedLabel { Text: "Speed"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatSpeedBase { Text: "0s"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatSpeedMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatRangeRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatRangeLabel { Text: "Range"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatRangeBase { Text: "0"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatRangeMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatPrecisionRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatPrecisionLabel { Text: "Precision"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatPrecisionBase { Text: "100%"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatPrecisionMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatKnockbackRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatKnockbackLabel { Text: "Knockback"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatKnockbackBase { Text: "0"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatKnockbackMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatMaxAmmoRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatMaxAmmoLabel { Text: "Max Ammo"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatMaxAmmoBase { Text: "0"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatMaxAmmoMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatPelletsRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatPelletsLabel { Text: "Pellets"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatPelletsBase { Text: "1"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatPelletsMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      Group #UnstableRiftsStatEffectTimeRow {
        Anchor: (Height: 20, Top: 2);
        LayoutMode: Left;
        Label #UnstableRiftsStatEffectTimeLabel { Text: "Effect Time"; Anchor: (Width: 95, Height: 20); Style: @StatLabelStyle; }
        Label #UnstableRiftsStatEffectTimeBase { Text: "0s"; Anchor: (Width: 55, Height: 20); Style: @StatValueStyle; }
        Label #UnstableRiftsStatEffectTimeMod { Text: ""; Anchor: (Height: 20); Style: @StatModStyle; }
      }

      } // end #UnstableRiftsStatsSection

      // ── Modifier section (visible when crouching) ──
      Group #UnstableRiftsModSection {
        LayoutMode: Top;

      Group #UnstableRiftsModSeparator { Anchor: (Height: 1, Top: 6, Left: 0, Right: 0); Background: @SepColor; }
      Label #UnstableRiftsMod0 { Text: ""; Anchor: (Height: 18, Top: 5); Style: @ModSlotStyle; }
      Label #UnstableRiftsMod1 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @ModSlotStyle; }
      Label #UnstableRiftsMod2 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @ModSlotStyle; }
      Label #UnstableRiftsMod3 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @ModSlotStyle; }
      Label #UnstableRiftsMod4 { Text: ""; Anchor: (Height: 18, Top: 1); Style: @ModSlotStyle; }

      } // end #UnstableRiftsModSection

      // ── Ammo section (hidden for melee weapons) ──
      Group #UnstableRiftsAmmoSection {
        LayoutMode: Top;

      // ── Separator before ammo ──
      Group { Anchor: (Height: 1, Top: 6, Left: 0, Right: 0); Background: @SepColor; }

      // ── Ammo counter row ──
      Group {
        Anchor: (Height: 28, Top: 6);
        LayoutMode: Left;

        Label #UnstableRiftsAmmoValue {
          Text: "0";
          Anchor: (Height: 28);
          Style: LabelStyle(
            FontName: "Secondary",
            FontSize: 22,
            TextColor: @BrightText,
            RenderBold: true,
            VerticalAlignment: Center,
            HorizontalAlignment: Start
          );
        }

        Label {
          Text: "/";
          Anchor: (Height: 28, Left: 4, Right: 3);
          Style: LabelStyle(
            FontSize: 14,
            TextColor: @DimText,
            VerticalAlignment: Center,
            HorizontalAlignment: Center
          );
        }

        Label #UnstableRiftsMaxAmmoValue {
          Text: "0";
          Anchor: (Height: 28);
          Style: LabelStyle(
            FontSize: 14,
            TextColor: @DimText,
            VerticalAlignment: Center,
            HorizontalAlignment: Start
          );
        }
      }

      // ── Ammo bar ──
      Group #UnstableRiftsAmmoBarTrack {
        Anchor: (Height: 5, Top: 4, Left: 0, Right: 0);
        Background: @BarTrack;

        Group #UnstableRiftsAmmoBarFill {
          Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
          Background: @AmmoFull;
        }
      }
      }
    }
    }
  }
}

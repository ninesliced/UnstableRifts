// ─────────────────────────────────────────────
//  UnstableRifts — Mob Spawner Configuration (Level Designer)
// ─────────────────────────────────────────────

@PanelBg = #1a1e26(0.92);
@TitleColor = #d9c18a;
@LabelColor = #8fa4b8;
@ValueColor = #e8ecf0;
@BtnBg = #2a3040;
@BtnHover = #3a4560;
@BtnText = #e8ecf0;
@BtnLabelStyle = LabelStyle(FontSize: 12, TextColor: @BtnText, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@BtnStyle = TextButtonStyle(
  Default: (Background: @BtnBg, LabelStyle: @BtnLabelStyle),
  Hovered: (Background: @BtnHover, LabelStyle: @BtnLabelStyle),
  Pressed: (Background: @BtnBg, LabelStyle: @BtnLabelStyle)
);
@SmallBtnLabelStyle = LabelStyle(FontSize: 11, TextColor: @BtnText, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@SmallBtnStyle = TextButtonStyle(
  Default: (Background: @BtnBg, LabelStyle: @SmallBtnLabelStyle),
  Hovered: (Background: @BtnHover, LabelStyle: @SmallBtnLabelStyle),
  Pressed: (Background: @BtnBg, LabelStyle: @SmallBtnLabelStyle)
);

Group #MobSpawnerRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);

  // Overlay background
  Group {
    Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
    Background: #000000(0.5);
  }

  Group #MobSpawnerCenter {
    Anchor: (Width: 400, Height: 420);
    LayoutMode: Middle;

    Group #MobSpawnerPanel {
      Anchor: (Width: 400, Height: 420);
      Background: @PanelBg;
      LayoutMode: Top;
      Padding: (Horizontal: 16, Vertical: 12);

      // ── Title ──
      Label {
        Text: "MOB SPAWNER CONFIG";
        Anchor: (Height: 28);
        Style: LabelStyle(
          FontSize: 15,
          TextColor: @TitleColor,
          RenderBold: true,
          RenderUppercase: true,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      // ── Column Headers ──
      Group {
        Anchor: (Height: 20, Top: 8);
        LayoutMode: Left;
        Padding: (Left: 4);

        Label {
          Text: "MOB ID";
          Anchor: (Width: 180, Height: 20);
          Style: LabelStyle(FontSize: 11, TextColor: @LabelColor, RenderBold: true, HorizontalAlignment: Start, VerticalAlignment: Center);
        }

        Label {
          Text: "WEIGHT";
          Anchor: (Width: 100, Height: 20);
          Style: LabelStyle(FontSize: 11, TextColor: @LabelColor, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }
      }

      // ── Scrollable Mob List ──
      Group #MobListContainer {
        Anchor: (Top: 4);
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 6);
      }

      // ── Add Entry Button ──
      Group {
        Anchor: (Height: 32, Top: 8);
        LayoutMode: Left;

        TextButton #AddEntryBtn {
          Text: "+ ADD MOB";
          Anchor: (Width: 140, Height: 28);
          Style: @BtnStyle;
        }
      }

      // ── Spawn Count ──
      Group {
        Anchor: (Height: 32, Top: 8);
        LayoutMode: Left;

        Label {
          Text: "Spawn Count:";
          Anchor: (Width: 100, Height: 28);
          Style: LabelStyle(FontSize: 12, TextColor: @LabelColor, HorizontalAlignment: Start, VerticalAlignment: Center);
        }

        TextButton #SpawnCountMinusBtn {
          Text: "-";
          Anchor: (Width: 28, Height: 28);
          Style: @SmallBtnStyle;
        }

        Label #SpawnCountLabel {
          Text: "1";
          Anchor: (Width: 40, Height: 28);
          Style: LabelStyle(FontSize: 13, TextColor: @ValueColor, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        }

        TextButton #SpawnCountPlusBtn {
          Text: "+";
          Anchor: (Width: 28, Height: 28);
          Style: @SmallBtnStyle;
        }
      }

      // ── Action Buttons ──
      Group {
        Anchor: (Height: 40, Top: 10);
        LayoutMode: Left;
        Padding: (Horizontal: 10);

        TextButton #SaveBtn {
          Text: "SAVE";
          Anchor: (Width: 120, Height: 32);
          Style: @BtnStyle;
        }

        TextButton #CloseBtn {
          Text: "CLOSE";
          Anchor: (Width: 120, Height: 32, Left: 10);
          Style: @BtnStyle;
        }
      }
    }
  }
}

// ─────────────────────────────────────────────
//  UnstableRifts — Door Configuration (Level Designer)
// ─────────────────────────────────────────────

@PanelBg = #1a1e26(0.92);
@TitleColor = #d9c18a;
@LabelColor = #8fa4b8;
@ValueColor = #e8ecf0;
@BtnBg = #2a3040;
@BtnHover = #3a4560;
@BtnText = #e8ecf0;
@BtnLabelStyle = LabelStyle(FontSize: 12, TextColor: @BtnText, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@BtnStyle = TextButtonStyle(
  Default: (Background: @BtnBg, LabelStyle: @BtnLabelStyle),
  Hovered: (Background: @BtnHover, LabelStyle: @BtnLabelStyle),
  Pressed: (Background: @BtnBg, LabelStyle: @BtnLabelStyle)
);

Group #DoorConfigRoot {
  Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);

  // Overlay background
  Group {
    Anchor: (Left: 0, Top: 0, Right: 0, Bottom: 0);
    Background: #000000(0.5);
  }

  Group #DoorConfigCenter {
    Anchor: (Width: 300, Height: 220);
    LayoutMode: Middle;

    Group #DoorConfigPanel {
      Anchor: (Width: 300, Height: 220);
      Background: @PanelBg;
      LayoutMode: Top;
      Padding: (Horizontal: 20, Vertical: 16);

      Label #DoorConfigTitle {
        Text: "DOOR CONFIGURATION";
        Anchor: (Height: 28);
        Style: LabelStyle(
          FontSize: 15,
          TextColor: @TitleColor,
          RenderBold: true,
          RenderUppercase: true,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
      }

      Label #CurrentModeLabel {
        Text: "Current mode: ACTIVATOR";
        Anchor: (Height: 24, Top: 8);
        Style: LabelStyle(FontSize: 13, TextColor: @ValueColor, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
      }

      Label {
        Text: "Select the door mode:";
        Anchor: (Height: 24, Top: 8);
        Style: LabelStyle(FontSize: 12, TextColor: @LabelColor, HorizontalAlignment: Center, VerticalAlignment: Center);
      }

      Group {
        Anchor: (Height: 44, Top: 16);
        LayoutMode: Left;
        Padding: (Horizontal: 10);

        TextButton #KeyDoorBtn {
          Text: "KEY DOOR";
          Anchor: (Width: 120, Height: 36);
          Style: @BtnStyle;
        }

        TextButton #ActivatorDoorBtn {
          Text: "ACTIVATOR DOOR";
          Anchor: (Width: 120, Height: 36, Left: 10);
          Style: @BtnStyle;
        }
      }
    }
  }
}
